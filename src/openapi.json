{
  "openapi": "3.0.3",
  "info": {
    "title": "GateAPI",
    "description": "LLM API aggregation gateway with model authenticity detection, multi-channel routing, and OpenAI/Anthropic compatible endpoints.",
    "version": "0.1.0",
    "license": { "name": "Apache-2.0" }
  },
  "servers": [{ "url": "/", "description": "Current server" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" },
      "adminToken": { "type": "apiKey", "in": "header", "name": "x-admin-token" }
    },
    "schemas": {
      "ChatMessage": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "type": "string", "enum": ["system", "user", "assistant"] },
          "content": { "type": "string" }
        }
      },
      "ChatCompletionRequest": {
        "type": "object",
        "required": ["model", "messages"],
        "properties": {
          "model": { "type": "string", "example": "gpt-4o" },
          "messages": { "type": "array", "items": { "$ref": "#/components/schemas/ChatMessage" } },
          "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
          "top_p": { "type": "number" },
          "max_tokens": { "type": "integer" },
          "stream": { "type": "boolean", "default": false }
        }
      },
      "Channel": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["openai", "anthropic"] },
          "endpoint": { "type": "string" },
          "models": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string", "enum": ["enabled", "disabled"] },
          "weight": { "type": "integer" },
          "priority": { "type": "integer" },
          "costRate": { "type": "number" },
          "balanceType": { "type": "string", "enum": ["new-api", "one-api", "openai", "close-ai"] }
        }
      }
    }
  },
  "paths": {
    "/v1/chat/completions": {
      "post": {
        "tags": ["API"],
        "summary": "Chat Completions (OpenAI-compatible)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChatCompletionRequest" } } } },
        "responses": {
          "200": { "description": "Completion response" },
          "401": { "description": "Invalid API key" },
          "404": { "description": "No channel for model" },
          "502": { "description": "All channels failed" }
        }
      }
    },
    "/v1/messages": {
      "post": {
        "tags": ["API"],
        "summary": "Messages (Anthropic-compatible)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": { "200": { "description": "Message response" } }
      }
    },
    "/v1/models": {
      "get": {
        "tags": ["API"],
        "summary": "List available models",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Model list" } }
      }
    },
    "/v1/embeddings": {
      "post": {
        "tags": ["API"],
        "summary": "Embeddings (passthrough)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Embedding response" } }
      }
    },
    "/admin/channels": {
      "get": {
        "tags": ["Admin"],
        "summary": "List all channels",
        "security": [{ "adminToken": [] }],
        "responses": { "200": { "description": "Channel list" } }
      },
      "post": {
        "tags": ["Admin"],
        "summary": "Add a channel",
        "security": [{ "adminToken": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Channel" } } } },
        "responses": { "200": { "description": "Channel added" } }
      }
    },
    "/admin/channels/{id}": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get channel by ID",
        "security": [{ "adminToken": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Channel detail" } }
      },
      "put": {
        "tags": ["Admin"],
        "summary": "Update channel",
        "security": [{ "adminToken": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Channel updated" } }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "Delete channel",
        "security": [{ "adminToken": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Channel deleted" } }
      }
    },
    "/admin/models": {
      "get": {
        "tags": ["Admin"],
        "summary": "List aggregated models with channel info and cost rates",
        "security": [{ "adminToken": [] }],
        "responses": { "200": { "description": "Model list with pricing" } }
      }
    },
    "/admin/stats": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get usage statistics",
        "security": [{ "adminToken": [] }],
        "parameters": [{ "name": "hours", "in": "query", "schema": { "type": "integer", "default": 24 } }],
        "responses": { "200": { "description": "Stats object" } }
      }
    },
    "/admin/logs": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get recent request logs",
        "security": [{ "adminToken": [] }],
        "parameters": [{ "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } }],
        "responses": { "200": { "description": "Log entries" } }
      }
    },
    "/admin/detect/{channelId}": {
      "get": {
        "tags": ["Detection"],
        "summary": "Get detection results for a channel",
        "security": [{ "adminToken": [] }],
        "parameters": [{ "name": "channelId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Detection results" } }
      },
      "post": {
        "tags": ["Detection"],
        "summary": "Run detection on a channel",
        "security": [{ "adminToken": [] }],
        "parameters": [{ "name": "channelId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Detection started" } }
      }
    },
    "/admin/webhook": {
      "get": {
        "tags": ["Settings"],
        "summary": "Get webhook config",
        "security": [{ "adminToken": [] }],
        "responses": { "200": { "description": "Webhook config" } }
      },
      "put": {
        "tags": ["Settings"],
        "summary": "Update webhook config",
        "security": [{ "adminToken": [] }],
        "responses": { "200": { "description": "Config updated" } }
      }
    },
    "/admin/cache": {
      "get": {
        "tags": ["Settings"],
        "summary": "Get cache stats",
        "security": [{ "adminToken": [] }],
        "responses": { "200": { "description": "Cache stats" } }
      },
      "put": {
        "tags": ["Settings"],
        "summary": "Update cache config",
        "security": [{ "adminToken": [] }],
        "responses": { "200": { "description": "Config updated" } }
      },
      "delete": {
        "tags": ["Settings"],
        "summary": "Clear cache",
        "security": [{ "adminToken": [] }],
        "responses": { "200": { "description": "Cache cleared" } }
      }
    },
    "/admin/model-fallback": {
      "get": {
        "tags": ["Settings"],
        "summary": "Get model fallback chains",
        "security": [{ "adminToken": [] }],
        "responses": { "200": { "description": "Fallback config" } }
      },
      "put": {
        "tags": ["Settings"],
        "summary": "Update model fallback chains",
        "security": [{ "adminToken": [] }],
        "responses": { "200": { "description": "Config updated" } }
      }
    },
    "/admin/balance": {
      "get": {
        "tags": ["Admin"],
        "summary": "Query all channel balances",
        "security": [{ "adminToken": [] }],
        "responses": { "200": { "description": "Balance results" } }
      }
    },
    "/admin/export-tool": {
      "get": {
        "tags": ["Admin"],
        "summary": "Export config for external tools (CherryStudio, Cursor, etc.)",
        "security": [{ "adminToken": [] }],
        "parameters": [{ "name": "format", "in": "query", "schema": { "type": "string", "enum": ["openai", "cherrystudio", "cursor"], "default": "openai" } }],
        "responses": { "200": { "description": "Tool config" } }
      }
    },
    "/admin/config/export": {
      "get": {
        "tags": ["Admin"],
        "summary": "Export full config backup",
        "security": [{ "adminToken": [] }],
        "responses": { "200": { "description": "Config JSON" } }
      }
    },
    "/admin/config/import": {
      "post": {
        "tags": ["Admin"],
        "summary": "Import config from backup",
        "security": [{ "adminToken": [] }],
        "responses": { "200": { "description": "Import result" } }
      }
    },
    "/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health check",
        "responses": { "200": { "description": "Service status" } }
      }
    }
  }
}
